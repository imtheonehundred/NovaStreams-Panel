{
  "name": "novastreams-panel",
  "version": "1.0.0",
  "description": "Open-source IPTV Restream Panel — MPD/HLS/RTMP → HLS with sub-second on-demand startup",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/imtheonehundred/NovaStreams-Panel"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:vite": "vite --config vite.config.js",
    "build:frontend": "vite build --config vite.config.js",
    "lint": "eslint server.js services/**/*.js middleware/**/*.js repositories/**/*.js routes/**/*.js public/js/src/**/*.js tests/**/*.js eslint.config.js",
    "lint:changed": "node scripts/lint-changed.js",
    "format": "prettier --write .",
    "preview": "vite preview --config vite.config.js",
    "frontend:dev": "vite --config vite.config.js",
    "frontend:build": "vite build --config vite.config.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "verify:preset": "node scripts/verify-mpegts-preset.js",
    "bootstrap-db": "node scripts/bootstrap-database.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-redis": "^9.0.0",
    "cookie": "^1.1.1",
    "cors": "^2.8.5",
    "csrf": "^3.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "geoip-lite": "^2.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.1",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "node-telegram-bot-api": "^0.64.0",
    "ssh2": "^1.16.0",
    "systeminformation": "^5.31.5",
    "tree-kill": "^1.2.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "better-sqlite3": "^12.8.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "supertest": "^7.1.0",
    "vite": "^8.0.5"
  }
}
