# MariaDB / MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=iptv
DB_PASSWORD=change_me
DB_NAME=iptv_panel

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Session
SESSION_SECRET=change_me_to_random_string

# Server
PORT=3000

# Remote LB SSH provisioning: master switch. When 1, admins can enable provisioning in Settings → Streaming (DB key streaming_provisioning_enabled). When unset/0, provisioning is always off.
# ENABLE_SERVER_PROVISIONING=1
# AGENT_SECRET=your_shared_secret_for_remote_agents

# Streaming: `node` (FFmpeg TS via Node pipe; HLS from panel streams/) or `nginx` (HLS on disk under IPTV_DISK_ROOT; TS via FFmpeg pipe + Node; Nginx proxies /live/ — see deploy/nginx-iptv.conf)
STREAMING_MODE=node
# Production: HLS at /var/lib/iptv/hls/{id}/ (Nginx alias); /live/ is proxied to Node (no TS files on disk)
# IPTV_DISK_ROOT=/var/lib/iptv
# Public origin for signed playback URLs (Xtream redirects, panel preview); no trailing slash.
# Dev (Node only): use http://127.0.0.1:3000 — if you use http://127.0.0.1 without port, browsers default to :80 and VLC cannot reach Node on :3000 unless nginx proxies.
# PUBLIC_STREAM_BASE_URL=https://yourdomain.com
# Panel + nginx-mode line URLs: TTL clamped to 30–60s (default 45)
# PLAYBACK_TOKEN_TTL_SEC=45
# PLAYBACK_TOKEN_TTL_LEGACY_SEC=3600
# Same-machine VLC: token-free /streams/{id}/stream.ts (loopback TCP only; dev/local)
# ALLOW_LOCAL_UNSIGNED_TS=1
# Browser preview without token: owner session + cookies (same origin)
# ALLOW_ADMIN_PREVIEW_UNSIGNED_TS=1

# ─── Streaming Performance (optimized for fast startup) ────────────────────
# MPEG-TS prebuffer: smaller ring = faster fill for on-demand streams
# PREBUFFER_ENABLED=1
# PREBUFFER_SIZE_MB=1
# PREBUFFER_ON_DEMAND_MIN_BYTES=262144
# PREBUFFER_ON_DEMAND_MAX_WAIT_MS=500
# Ingest style: webapp = low-latency mode with +nobuffer -flags low_delay
# STREAM_INGEST_STYLE=webapp
# On-demand: max ms to wait for stream ready after auto-start (first client triggers FFmpeg)
# ON_DEMAND_START_MS=120000
